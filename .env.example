# Database
#
# Local (Docker):
#   npm run db:local:up
#   npm run db:migrate
#   npm run db:seed
#
# DATABASE_URL="postgresql://pos:pos_local_dev@localhost:5432/pos?schema=public"
# DIRECT_URL="postgresql://pos:pos_local_dev@localhost:5432/pos?schema=public"
#
# Neon (production):
# DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require&pgbouncer=true"
# DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require"

DATABASE_URL="postgresql://pos:pos_local_dev@localhost:5432/pos?schema=public"
DIRECT_URL="postgresql://pos:pos_local_dev@localhost:5432/pos?schema=public"

# NextAuth
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"
# Vercel: set AUTH_URL to your custom domain, e.g. https://app.example.com
# (falls back to https://$VERCEL_URL when AUTH_URL is unset)

# Vercel + Railway Postgres:
# DATABASE_URL = Railway pooled/public URL (?sslmode=require)
# DIRECT_URL = Railway direct URL (same host without pooler, or same as DATABASE_URL)

# Seed (never set in production)
# SEED_ALLOW="true"

# Cloudinary (Phase 2+)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Rate limiting (required in production — Upstash Redis)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
# TRUST_PROXY="true"

# Signup
# SIGNUP_DISABLED="true"

# Platform admin bootstrap (required when seeding platform user password)
# PLATFORM_ADMIN_PASSWORD=""

# Production API docs / health
# OPENAPI_ENABLED="false"
# HEALTH_DETAILED="true"

# Platform support (shown on billing page when subscription is inactive)
PLATFORM_SUPPORT_EMAIL="superadmin@platform.com"

# Stripe (future billing integration)
# STRIPE_SECRET_KEY=""
# STRIPE_WEBHOOK_SECRET=""

# Optional: use Argon2 when argon2 package is installed
# USE_ARGON2="true"

# Sentry (optional)
# SENTRY_DSN=""
