# Database
#
# Local (Docker):
#   npm run db:local:up
#   npm run db:migrate
#   npm run db:seed
#
# DATABASE_URL="postgresql://pos:pos_local_dev@localhost:5432/pos?schema=public"
# DIRECT_URL="postgresql://pos:pos_local_dev@localhost:5432/pos?schema=public"
#
# Neon (production):
# DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require&pgbouncer=true"
# DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require"

DATABASE_URL="postgresql://pos:pos_local_dev@localhost:5432/pos?schema=public"
DIRECT_URL="postgresql://pos:pos_local_dev@localhost:5432/pos?schema=public"

# NextAuth
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# Seed (never set in production)
# SEED_ALLOW="true"

# Cloudinary (Phase 2+)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Rate limiting (optional - Upstash Redis)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
