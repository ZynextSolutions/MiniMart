    "html5-qrcode": "^2.3.8",
    "jsbarcode": "^3.12.3",
    "lucide-react": "^0.469.0",
    "next": "^15.1.3",
    "next-auth": "5.0.0-beta.25",
    "next-themes": "^0.4.4",
    "pdf-lib": "^1.17.1",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.2",
    "recharts": "^3.9.0",
    "sonner": "^1.7.1",
