{
  "name": "pos",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "vercel-build": "prisma migrate deploy && next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest",
    "test:ci": "vitest run",
    "test:integration": "INTEGRATION_TEST=true vitest run --config vitest.integration.config.ts",
    "validate:env": "tsx scripts/validate-env.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "db:reset-platform-admin": "tsx scripts/reset-platform-admin-password.ts",
    "db:backfill-account-mapping": "tsx scripts/backfill-account-mapping.ts",
    "db:studio": "prisma studio",
    "db:local:up": "docker compose up -d",
    "db:local:down": "docker compose down",
    "db:local:setup": "docker compose up -d && sleep 3 && prisma migrate dev --name init && prisma db seed",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.7.4",
    "@hookform/resolvers": "^3.9.1",
